# ===================== ENVIRONMENT =====================
# Options: development, staging, production
ENVIRONMENT=development
DEBUG=True

# ===================== DJANGO SETTINGS =====================
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-change-in-production-12345abcde

# Development: localhost,127.0.0.1
# Production: safecloud.com,www.safecloud.com,api.safecloud.com
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Production: https://yourdomain.com
TRUSTED_ORIGINS=http://localhost:3000

# ===================== DATABASE =====================
# SQLite (Development) - automatically used when DB_ENGINE is not postgresql
# PostgreSQL (Production) - set when ENVIRONMENT=production

DB_ENGINE=django.db.backends.postgresql  # Use 'sqlite3' for development
DB_NAME=safecloud_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DB_SSL=False

# ===================== REDIS =====================
# Required for caching, sessions, and celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===================== SECURITY =====================
# Production only
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ===================== CORS CONFIGURATION =====================
# Development: http://localhost:3000
# Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://frontend:3000

# ===================== EMAIL CONFIGURATION =====================
# Development: console (prints emails to console)
# Production: SMTP (sends real emails)

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# For production with Gmail:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

DEFAULT_FROM_EMAIL=noreply@safecloud.com

# ===================== CELERY & ASYNC TASKS =====================
# Uses Redis by default
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ===================== AWS S3 (Optional) =====================
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# ===================== LOGGING =====================
LOG_LEVEL=DEBUG  # INFO for production

# ===================== MONITORING =====================
# Optional: Error tracking with Sentry
SENTRY_DSN=

# ===================== FEATURES =====================
ENABLE_2FA=True
ENABLE_NOTIFICATIONS=True
ENABLE_AUDIT_LOGGING=True
ENABLE_EMAIL_NOTIFICATIONS=False  # Set to True in production with email configured

# ===================== JWT TOKENS =====================
JWT_ACCESS_TOKEN_LIFETIME=900  # 15 minutes in seconds
JWT_REFRESH_TOKEN_LIFETIME=86400  # 24 hours in seconds
